  .dg-h .hr{font-family:var(--mono);font-size:10px;color:var(--violet);font-weight:700;margin-left:8px}
  .dg-row{display:flex;align-items:center;gap:8px;padding:6px 12px;border-bottom:1px solid #d8eede;font-size:12px}
  .dg-row:last-child{border-bottom:0}
  .dg-rank{font-family:var(--mono);font-size:10px;color:var(--dim);width:16px}
  .dg-mk{width:16px;text-align:center;font-weight:700}
  .dg-gate{flex:none;width:20px;height:20px;display:grid;place-items:center;font-size:11px;font-weight:700;border-radius:3px;font-family:var(--mono);border:1px solid rgba(16,48,34,.25)}
