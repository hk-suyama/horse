  .dg-meta{font-family:var(--mono);font-size:9px;color:var(--dim)}
  .dg-sc{font-family:var(--mono);font-weight:700;color:var(--amber);min-width:36px;text-align:right}
  .dg-sc.hot{color:var(--red)}
  .dg-yv{font-family:var(--mono);font-weight:700;color:var(--violet);min-width:40px;text-align:right;font-size:11px}
  .foot{text-align:center;font-size:9px;color:var(--dim);padding:18px;line-height:2;font-family:var(--mono)}
  .foot b{color:var(--amber)}
