    --w5:#e8b800;--w6:#2faa55;--w7:#e07b1f;--w8:#e06b9a;}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  body{background:#cfe8d6;color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased}
  .wrap{max-width:430px;margin:0 auto;min-height:100vh;background:var(--bg);
    background-image:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(16,48,34,.035) 2px,rgba(16,48,34,.035) 3px);
    box-shadow:0 0 40px rgba(16,48,34,.08) inset}
  @media(min-width:900px){.wrap{max-width:1280px}
    #main.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(420px,1fr));gap:0 14px;align-items:start;padding:0 6px}}
  header{background:var(--board);border-bottom:2px solid #b7dcc2;padding:14px 16px 12px;box-shadow:0 2px 0 var(--slot)}
  .brand{display:flex;align-items:center;gap:10px}
  .brand .b{font-size:18px;font-weight:700;letter-spacing:.32em;color:var(--amber);font-family:var(--mono)}
  .brand .sub{margin-left:auto;font-size:8px;letter-spacing:.2em;color:var(--dim);font-family:var(--mono)}
  @media(min-width:900px){.brand .b{font-size:22px}}
  .ticker{margin-top:10px;font-size:10px;letter-spacing:.05em;color:var(--ink2);white-space:nowrap;overflow:hidden;font-family:var(--mono)}
  .ticker span{display:inline-block;animation:scroll 26s linear infinite}
  @keyframes scroll{from{transform:translateX(100%)}to{transform:translateX(-100%)}}
  .controls{display:flex;flex-wrap:wrap;gap:6px;align-items:center;padding:10px 14px 4px}
  .venues{display:flex;gap:6px;flex:1;min-width:200px}
  .venue{flex:1;text-align:center;padding:8px 0;font-size:13px;font-weight:700;color:var(--dim);background:var(--slot);border:1px solid #bfe0c9;border-radius:2px;cursor:pointer}
  .venue.on{color:#eaf7ee;background:var(--amber);box-shadow:0 0 10px rgba(18,122,74,.3)}
  .venue small{display:block;font-size:8px;font-weight:400;margin-top:1px;font-family:var(--mono)}
  .viewtabs{display:flex;gap:6px}
  .vtab{font-size:11px;font-weight:700;padding:8px 14px;color:var(--dim);background:var(--slot);border:1px solid #bfe0c9;border-radius:2px;cursor:pointer;font-family:var(--mono)}
  .vtab.on{color:#eaf7ee;background:var(--ink2)}
  .toolbar{display:flex;flex-wrap:wrap;gap:6px;padding:6px 14px 10px;align-items:center}
  .label{font-size:10px;color:var(--dim);font-family:var(--mono);margin-right:2px}
  .toggle{display:inline-flex;border:1px solid #9fcfb1;border-radius:6px;overflow:hidden;flex-wrap:wrap}
  .toggle button{font-family:var(--mono);font-size:11px;font-weight:700;padding:7px 12px;border:0;background:var(--board);color:var(--dim);cursor:pointer}
  .toggle button.on{background:var(--amber);color:#eaf7ee}
  .sorts{display:flex;gap:6px;font-family:var(--mono)}
  .sort{white-space:nowrap;font-size:10px;padding:6px 11px;color:var(--dim);border:1px solid var(--slot);border-radius:2px;cursor:pointer;background:var(--board)}
  .sort.on{color:var(--amber);border-color:#9fcfb1}
  main{padding-bottom:30px}
  .race{margin:0 14px 16px;background:var(--board);border:1px solid #bfe0c9;box-shadow:0 0 0 1px var(--slot)}
  @media(min-width:900px){.race{margin:0 0 16px}}
  .rhead{display:flex;align-items:center;gap:10px;padding:10px 14px;background:linear-gradient(180deg,#e6f5eb,#dff0e5);border-bottom:2px solid #b7dcc2}
  .rno{font-size:20px;font-weight:700;color:var(--amber);min-width:42px;font-family:var(--mono)}
  .rttl{font-size:14px;font-weight:700}
  .rank{font-family:var(--mono);font-size:11px;font-weight:700;padding:2px 7px;border-radius:4px;margin-left:6px}
  .rank.S{background:var(--gold);color:#fff}.rank.Ap{background:var(--red);color:#fff}
  .rank.A{background:var(--amber);color:#fff}.rank.B{background:#cfe0d6;color:var(--ink2)}
  .rsub{margin-left:auto;text-align:right;font-size:9px;color:var(--dim);line-height:1.5;font-family:var(--mono)}
  .anom{display:flex;align-items:center;gap:8px;padding:8px 14px;background:#e8f5ec;border-bottom:1px solid var(--slot)}
  .anom .k{font-size:9px;color:var(--dim);min-width:54px}
  .anom .meter{flex:1;height:6px;background:var(--slot);border-radius:3px;overflow:hidden}
  .anom .meter>i{display:block;height:100%;background:linear-gradient(90deg,var(--amber),var(--red))}
  .anom .v{font-size:13px;font-weight:700;color:var(--red);min-width:30px;text-align:right;font-family:var(--mono)}
  .anom .haran{font-family:var(--mono);font-size:10px;color:var(--violet);font-weight:700;border-left:1px solid var(--slot);padding-left:8px;margin-left:2px}
  .anom .haran b{font-size:13px}
  .cmt{padding:7px 14px;font-size:10.5px;color:var(--red);background:#fdf1ec;border-bottom:1px solid var(--slot);line-height:1.5}
  .cmt::before{content:"▶ 解析メモ ";font-weight:700;font-size:9px;color:var(--amber)}
  .rows{padding:0}
  .row{display:flex;align-items:center;gap:8px;padding:8px 12px;background:linear-gradient(180deg,var(--slot2),var(--slot));border-bottom:2px solid #c4e3cd;position:relative}
  .row.hot{background:linear-gradient(90deg,rgba(194,65,12,.10),var(--slot2) 70%)}
  .mark{flex:none;width:20px;text-align:center;font-size:15px;font-weight:700}
  .mark.m0{color:var(--red)}.mark.m1{color:var(--ink)}.mark.m2{color:var(--ink2)}.mark.m3{color:var(--cyan)}.mark.m4{color:var(--dim)}
  .gate{flex:none;width:25px;height:25px;display:grid;place-items:center;font-size:12px;font-weight:700;border-radius:3px;font-family:var(--mono);border:1px solid rgba(16,48,34,.25)}
