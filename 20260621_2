  .pos.win{color:var(--green)}.pos.plc{color:var(--amber)}.pos.oth{color:var(--dim)}
  .dg{margin:0 14px 14px;background:var(--board);border:1px solid #bfe0c9;box-shadow:0 0 0 1px var(--slot)}
