const VENUES=[...new Set(RACES.map(r=>r.jyo))];
let venue=VENUES[0], view='races', horseOrder='score', raceSort='no';
const RSORTS=[['no','R順'],['anom','異常度順'],['haran','波乱度順'],['rank','信頼度順']];
const MORD={'◎':0,'○':1,'▲':2,'×':3,'△':4};
const MCLS={'◎':'m0','○':'m1','▲':'m2','×':'m3','△':'m4'};
const RANKORD={'S':0,'A+':1,'A':2,'B':3};
function wcls(w){return w?('w'+w):'w0';}
function rankcls(r){return r==='A+'?'Ap':r==='S'?'S':r==='A'?'A':'B';}
function sortHorses(hs){
  const a=[...hs];
  if(horseOrder==='gate') a.sort((x,y)=>x.g-y.g);
  else if(horseOrder==='mark') a.sort((x,y)=>(MORD[x.mark]??9)-(MORD[y.mark]??9)||y.score-x.score);
  else if(horseOrder==='yval') a.sort((x,y)=>(y.yval??-1)-(x.yval??-1)||y.score-x.score);
  else a.sort((x,y)=>y.score-x.score);
  return a;
}
function hrow(h,scoreRank){
  const hot=h.score>=50;
  const gap=(h.ninki&&scoreRank!=null)?(h.ninki-(scoreRank+1)):null;
  const flag=(gap&&gap>=3)?`<span class="flag">▼妙味</span>`:'';
  const w=Math.min(100,h.score);
  const col=hot?'var(--red)':h.score>=20?'var(--amber)':'#bcd8c6';
  const posCell=h.order!=null?`<div class="pos ${h.order===1?'win':h.order<=3?'plc':'oth'}">${h.order}</div>`:'';
  const mk=h.mark?`<div class="mark ${MCLS[h.mark]}">${h.mark}</div>`:`<div class="mark"></div>`;
  const sf=h.s?`<span class="sf">s</span>`:'';
  return `<div class="row ${hot?'hot':''}">
    ${mk}
    <div class="gate ${wcls(h.waku)}">${h.g}</div>
    <div class="body"><div class="nm">${h.name}${sf}${flag}</div>
      <div class="sub2">${h.ninki_t} ・ ${h.odds_t}${h.tm!=null?` ・ <span class="tm">TM${h.tm}</span>`:''}</div></div>
    <div class="leds">
      <div class="led"><span class="n score ${hot?'hot':''}">${h.score.toFixed(1)}</span>
        <div class="scorebar"><i style="width:${w}%;background:${col}"></i></div><div class="l">SCORE</div></div>
      <div class="led"><span class="n yv">${h.yval!=null?h.yval:'—'}</span><div class="l">解析</div></div>
      <div class="led"><span class="n sg">${h.sigma.toFixed(1)}</span><div class="l">σ</div></div>
      <div class="led"><span class="n st">${h.stealth.toFixed(2)}</span><div class="l">ST</div></div>
    </div>${posCell}</div>`;
}
function card(r){
  const byScore=[...r.horses].sort((a,b)=>b.score-a.score);
  const rankMap=new Map(byScore.map((h,i)=>[h.g,i]));
  const disp=sortHorses(r.horses);
  const w=Math.min(100,r.race);
  const rk=r.rank?`<span class="rank ${rankcls(r.rank)}">${r.rank}</span>`:'';
  const cmt=r.comment?`<div class="cmt">${r.comment}</div>`:'';
  const haran=r.haran!=null?`<span class="haran">波乱 <b>${r.haran}</b></span>`:'';
  return `<div class="race">
    <div class="rhead"><span class="rno">${r.no}R</span><span class="rttl">${r.jyo}${r.no}R</span>${rk}
      <span class="rsub">${r.post?'発走 '+r.post:r.last}<br>${r.n}頭</span></div>
    <div class="anom"><span class="k">異常度/波乱度</span>
      <span class="meter"><i style="width:${w}%"></i></span><span class="v">${r.race.toFixed(0)}</span>${haran}</div>
    ${cmt}
    <div class="rows">${disp.map(h=>hrow(h,rankMap.get(h.g))).join('')}</div></div>`;
}
function digestCard(r){
  const top=[...r.horses].sort((a,b)=>b.score-a.score).slice(0,5);
  const rk=r.rank?`<span class="rank ${rankcls(r.rank)}">${r.rank}</span>`:'';
  const haran=r.haran!=null?`<span class="hr">波乱 ${r.haran}</span>`:'';
  const rows=top.map((h,i)=>{
    const hot=h.score>=50;
    const mk=h.mark?`<span class="dg-mk ${MCLS[h.mark]}">${h.mark}</span>`:`<span class="dg-mk"></span>`;
    return `<div class="dg-row"><span class="dg-rank">${i+1}</span>${mk}
      <span class="dg-gate ${wcls(h.waku)}">${h.g}</span>
      <span class="dg-nm">${h.name}${h.s?' <span class="sf">s</span>':''}</span>
      <span class="dg-meta">${h.ninki_t}</span>
      <span class="dg-yv">${h.yval!=null?'解'+h.yval:''}</span>
      <span class="dg-sc ${hot?'hot':''}">${h.score.toFixed(1)}</span></div>`;}).join('');
  return `<div class="dg"><div class="dg-h"><span class="r">${r.no}R</span><span class="t">${r.jyo}${r.no}R</span>${rk}
      <span class="a">異常度 ${r.race.toFixed(0)}</span>${haran}</div>${rows}</div>`;
}
function render(){
  document.getElementById('venues').innerHTML=VENUES.map(v=>{
    const c=RACES.filter(r=>r.jyo===v).length;
    return `<span class="venue ${v===venue?'on':''}" data-v="${v}">${v}<small>${c}R</small></span>`;}).join('');
  document.getElementById('venues').querySelectorAll('.venue').forEach(e=>e.onclick=()=>{venue=e.dataset.v;render();});
  document.querySelectorAll('.vtab').forEach(t=>t.classList.toggle('on',t.dataset.view===view));
  document.getElementById('toolbar').style.display=view==='races'?'flex':'none';
  document.querySelectorAll('#ordertoggle button').forEach(b=>b.classList.toggle('on',b.dataset.order===horseOrder));
  document.getElementById('sorts').innerHTML=RSORTS.map(([k,l])=>`<div class="sort ${k===raceSort?'on':''}" data-k="${k}">${l}</div>`).join('');
  document.getElementById('sorts').querySelectorAll('.sort').forEach(e=>e.onclick=()=>{raceSort=e.dataset.k;render();});
  let rs=RACES.filter(r=>r.jyo===venue);
  const m=document.getElementById('main'); m.className='grid';
  if(view==='digest'){
    rs=rs.sort((a,b)=>a.no-b.no); m.innerHTML=rs.map(digestCard).join('');
  }else{
    if(raceSort==='no')rs=rs.sort((a,b)=>a.no-b.no);
    else if(raceSort==='anom')rs=rs.sort((a,b)=>b.race-a.race);
    else if(raceSort==='haran')rs=rs.sort((a,b)=>((b.haran??-1)-(a.haran??-1))||a.no-b.no);
    else if(raceSort==='rank')rs=rs.sort((a,b)=>((RANKORD[a.rank]??9)-(RANKORD[b.rank]??9))||a.no-b.no);
    m.innerHTML=rs.map(card).join('');
  }
}
document.querySelectorAll('.vtab').forEach(t=>t.onclick=()=>{view=t.dataset.view;render();});
document.querySelectorAll('#ordertoggle button').forEach(b=>b.onclick=()=>{horseOrder=b.dataset.order;render();});
render();
</script></body></html>
